{
  "env": {
    "browser": true,
    "es2021": true,
    "serviceworker": true,
    "node": true
  },
  "globals": {
    "__APP_VERSION__": "readonly",
    "googletag": "readonly",
    "gapi": "readonly",
    "google": "readonly",
    "TimestampTrigger": "readonly",
    "QRCode": "readonly",
    "Html5Qrcode": "readonly",
    "__AD_ADSENSE_CLIENT_ID__": "readonly",
    "__AD_ADSENSE_AD_SLOT__": "readonly",
    "__AD_GPT_REWARDED_PATH__": "readonly",
    "__AD_ADMOB_BANNER_ID__": "readonly",
    "__AD_ADMOB_REWARDED_ID__": "readonly",
    "__AD_IS_TESTING__": "readonly"
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off",
    "prefer-const": "error",
    "no-var": "error",
    "no-dupe-keys": "error",
    "no-duplicate-case": "error",
    "no-fallthrough": "error",
    "eqeqeq": ["error", "always"]
  }
}