# 輕鬆記帳 - 環境變數範本
# 複製此檔案為 .env.local 並填入實際值
# .env.local 已在 .gitignore 中，不會被提交到 Git

# Google OAuth Client ID (Google Cloud Console → Credentials → OAuth 2.0 Client ID)
# Web 登入使用。格式: xxxxxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# Google API Key (Google Cloud Console → Credentials → API Key)
# Google Picker 使用。建議限制 API Key 僅能呼叫 Drive API
VITE_GOOGLE_API_KEY=your-google-api-key

# 同步伺服器 URL (預設: 官方伺服器)
# 自建後端時可修改為自己的伺服器位址
VITE_SYNC_SERVER_URL=
